import pandas as pd

# Load MapReduce output
df = pd.read_csv("output.txt", header=None, names=["window","event","count"])

# Convert to feature matrix
features = df.pivot_table(
    index='window',
    columns='event',
    values='count',
    fill_value=0
).reset_index()

# Save
features.to_csv("features.csv", index=False)

print(features.head())
print("\nShape:", features.shape)
